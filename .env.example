# SQLite file (relative to prisma/)
DATABASE_URL="file:./dev.db"

# Public base URL — used in email "Got it" links. Set to your Pi's LAN address in prod.
APP_URL="http://localhost:3000"

# --- Email ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
MAIL_FROM="Home Dashboard <your-email@gmail.com>"
# RESEND_API_KEY=""

# --- Pi-hole (optional) ---
